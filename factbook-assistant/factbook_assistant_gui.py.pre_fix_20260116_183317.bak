"""
CITL Desktop LLM - Main GUI Entrypoint
This file intentionally forwards to the latest GUI implementation.
"""
from __future__ import annotations
import os, importlib
os.environ.setdefault("CITL_OLLAMA_HOST", "http://127.0.0.1:11434")
os.environ.setdefault("CITL_LLM_MODEL", "llama3.1:8b")
def _run():
    mod = importlib.import_module("factbook_assistant_gui_ffmpeg_graceful_v2")
    for name in ("main","run","run_app","start_gui","launch_gui","start"):
        fn = getattr(mod, name, None)
        if callable(fn):
            return fn()
    return None
if __name__ == "__main__":
    _run()
